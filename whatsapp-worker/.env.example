# --- OpenAI (IA de atendimento/agendamento) ---
OPENAI_API_KEY=sk-...
# Modelo com function calling. Default: gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# --- Firebase Admin ---
# Em produção (Cloud Run no mesmo projeto), NÃO precisa de service account:
# as credenciais padrão do ambiente (ADC) são usadas automaticamente.
# Basta o projectId bater com o do Firestore.
GOOGLE_CLOUD_PROJECT=ocartel-497f8

# Desenvolvimento local contra o emulador do Firestore (o Admin SDK detecta):
# FIRESTORE_EMULATOR_HOST=localhost:8080

# Local sem emulador: aponte para um service account JSON:
# GOOGLE_APPLICATION_CREDENTIALS=/caminho/serviceAccount.json
