# Copie para .env.local e preencha com as chaves do app Web do seu projeto Firebase.
# (Firebase Console → Configurações do projeto → Seus apps → Web → SDK setup)
# Tudo que começa com NEXT_PUBLIC_ é embutido no bundle do cliente (não é segredo
# para o Firebase Web — a segurança vem das regras do Firestore).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ocartel-497f8.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ocartel-497f8
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=ocartel-497f8.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=604756121837
NEXT_PUBLIC_FIREBASE_APP_ID=

# Liga os emuladores locais (auth/firestore) durante o desenvolvimento.
# Use "true" ao rodar `npm run emulators`. Em produção deixe vazio/false.
NEXT_PUBLIC_USE_EMULATORS=true

# Faz o Admin SDK (server action do booking) apontar para o emulador do Firestore
# em desenvolvimento. Deixe comentado/vazio em produção (usa ADC do App Hosting).
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# --- Apenas para rodar scripts/provision-super-admin.ts localmente ---
# Caminho para o JSON da service account (Firebase Console → Contas de serviço →
# Gerar nova chave privada). NUNCA versione esse arquivo. Em produção o App
# Hosting usa as credenciais padrão do ambiente (ADC) e isto não é necessário.
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
